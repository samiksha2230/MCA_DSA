   "source": [
    "# Program to solve recurrence relation\n",
    "# T(n) = T(n-1) + n\n",
    "\n",
    "def recurrence(n):\n",
    "    if n == 1:\n",
    "        return 1\n",
    "    return recurrence(n - 1) + n\n",
    "\n",
    "# Main Program\n",
    "n = int(input(\"Enter n: \"))\n",
    "print(\"T(\", n, \") =\", recurrence(n))"
   ]
  }
