   "source": [
    "\n",
    "\n",
    "# Greedy Algorithm - Activity Selection\n",
    "\n",
    "start = [1, 3, 0, 5, 8, 5]\n",
    "finish = [2, 4, 6, 7, 9, 9]\n",
    "\n",
    "print(\"Selected Activities:\")\n",
    "\n",
    "i = 0\n",
    "print(i, end=\" \")\n",
    "\n",
    "for j in range(1, len(start)):\n",
    "    if start[j] >= finish[i]:\n",
    "        print(j, end=\" \")\n",
    "        i = j\n",
    "\n"
   ]
  }
 ],
