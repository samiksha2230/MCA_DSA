   "source": [
    "#Recursion using Stack (Factorial)\n",
    "def factorial(n):\n",
    "    print(\"function call:factorial(\",n,\")\")\n",
    "    \n",
    "    if n==0 or n==1:\n",
    "        return 1\n",
    "    return n*factorial(n-1)\n",
    "num=5\n",
    "result=factorial(num)\n",
    "print(\"result:\",result)"
   ]
  }
